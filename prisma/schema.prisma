generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id          String     @id @default(cuid())
  title       String
  description String
  subject     String
  topics      String
  authorName  String
  createdAt   DateTime   @default(now())
  resources   Resource[]
  comments    Comment[]
}

model Resource {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id])
  url         String
  title       String
  description String
  language    String
  price       String
  type        String
  submittedBy String
  votes       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Comment {
  id         String    @id @default(cuid())
  postId     String
  post       Post      @relation(fields: [postId], references: [id])
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[] @relation("CommentReplies")
  content    String
  authorName String
  votes      Int       @default(0)
  createdAt  DateTime  @default(now())
}

model SidebarItem {
  id          String  @id @default(cuid())
  category    String
  title       String
  url         String
  description String
  featured    Boolean @default(false)
}
